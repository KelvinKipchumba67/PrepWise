generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String      @id @default(uuid())
  name      String?
  email     String      @unique
  password  String
  plans     StudyPlan[]
  createdAt DateTime    @default(now())
}

model StudyPlan {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  subject   String
  topics    String
  examDate  DateTime
  schedule  Json
  createdAt DateTime @default(now())
}
